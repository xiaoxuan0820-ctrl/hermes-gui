{
  "name": "hermes-gui",
  "version": "1.0.0",
  "description": "Hermes Agent 桌面客户端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --universal",
    "build:mac-arm": "electron-builder --mac dmg --arm64",
    "build:mac-x64": "electron-builder --mac dmg --x64",
    "build:win": "electron-builder --win nsis"
  },
  "keywords": ["hermes", "ai", "agent", "electron"],
  "author": "Biocherry <biocherry100@coze.email>",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.hermes.gui",
    "productName": "Hermes GUI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
